_RUNTIME_BASE: Path | None = None
_CONFIG_DIR_OVERRIDE: Path | None = None
_DATA_DIR_OVERRIDE: Path | None = None


def runtime_base_dir() -> Path:
    global _RUNTIME_BASE
    if _RUNTIME_BASE is not None:
        return _RUNTIME_BASE

    override = os.environ.get("SERMINAL_HOME")
    if override:
        _RUNTIME_BASE = Path(override).expanduser()
    else:
        _RUNTIME_BASE = Path.home()
    return _RUNTIME_BASE


def config_dir() -> Path:
    if _CONFIG_DIR_OVERRIDE is not None:
        return _CONFIG_DIR_OVERRIDE
    home = runtime_base_dir()
    base = os.environ.get("XDG_CONFIG_HOME", str(home / ".config"))
    return Path(base) / APP_NAME


def data_dir() -> Path:
    if _DATA_DIR_OVERRIDE is not None:
        return _DATA_DIR_OVERRIDE
    home = runtime_base_dir()
    base = os.environ.get("XDG_DATA_HOME", str(home / ".local" / "share"))
    return Path(base) / APP_NAME


def config_path() -> Path:
    return config_dir() / "config.json"


def libs_dir() -> Path:
    return data_dir() / "libs"


def ensure_dirs() -> None:
    global _RUNTIME_BASE, _CONFIG_DIR_OVERRIDE, _DATA_DIR_OVERRIDE

    def can_write(dir_path: Path) -> bool:
        try:
            dir_path.mkdir(parents=True, exist_ok=True)
            probe = dir_path / ".serminal_write_probe"
            with probe.open("w", encoding="utf-8") as f:
                f.write("ok")
            probe.unlink(missing_ok=True)
            return True
        except OSError:
            return False

    if can_write(config_dir()) and can_write(libs_dir()):
        return

    # Fallback for restricted environments (e.g. CI/sandboxes).
    try:
        local_base = Path.cwd() / ".serminal"
        _RUNTIME_BASE = local_base
        _CONFIG_DIR_OVERRIDE = local_base / ".config" / APP_NAME
        _DATA_DIR_OVERRIDE = local_base / ".local" / "share" / APP_NAME
        config_dir().mkdir(parents=True, exist_ok=True)
        libs_dir().mkdir(parents=True, exist_ok=True)
    except OSError as e:
        raise PermissionError(f"unable to create writable Serminal dirs: {e}") from e


def merge_defaults(raw: Dict) -> Dict:
    merged = dict(DEFAULT_SETTINGS)
    aliases = dict(DEFAULT_SETTINGS["aliases"])
    gui = dict(DEFAULT_SETTINGS["gui"])
    aliases.update(raw.get("aliases", {}))
    gui.update(raw.get("gui", {}))
    if gui.get("font") == "JetBrains Mono 11":
        # Migrate old default to Nerd Font-first default.
        gui["font"] = DEFAULT_SETTINGS["gui"]["font"]
    merged.update(raw)
    merged["aliases"] = aliases
    merged["gui"] = gui
    return merged


def load_settings() -> Dict:
    ensure_dirs()
    path = config_path()
    if not path.exists():
        save_settings(DEFAULT_SETTINGS)
        return dict(DEFAULT_SETTINGS)

    try:
        with path.open("r", encoding="utf-8") as f:
            raw = json.load(f)
    except (json.JSONDecodeError, OSError):
        raw = {}
    return merge_defaults(raw)


def save_settings(settings: Dict) -> None:
    ensure_dirs()
    with config_path().open("w", encoding="utf-8") as f:
        json.dump(settings, f, indent=2, sort_keys=True)


def bool_from_text(value: str) -> bool:
    return value.lower() in {"1", "true", "yes", "on"}


def gui_settings(settings: Dict) -> Dict:
    gui = dict(DEFAULT_SETTINGS["gui"])
    gui.update(settings.get("gui", {}))
    return gui


def gui_theme(theme_name: str) -> Dict[str, str]:
    return GUI_THEMES.get(theme_name, GUI_THEMES["openserialis"])


def script_shell(settings: Dict) -> str:
    shell_name = settings.get("shell", "bash")
    shell_path = shutil.which(shell_name)
    return shell_path or "/bin/bash"


def resolve_import(name: str, source_dir: Path) -> Path:
    candidates = [
        source_dir / f"{name}.sh",
        source_dir / "libs" / f"{name}.sh",
        libs_dir() / f"{name}.sh",
    ]
    for c in candidates:
        if c.exists() and c.is_file():
            return c
    raise FileNotFoundError(f"library '{name}' not found in local libs or {libs_dir()}")


def expand_tssh(path: Path, visited_libs: Set[str]) -> str:
    source_dir = path.parent
    out: List[str] = []
    import_re = re.compile(r"^\s*@import\s+([A-Za-z0-9_./-]+)\s*$")

    for line in path.read_text(encoding="utf-8").splitlines():
        m = import_re.match(line)
        if not m:
            out.append(line)
            continue

        lib_name = m.group(1)
        if lib_name in visited_libs:
            continue
        visited_libs.add(lib_name)

        lib_path = resolve_import(lib_name, source_dir)
        out.append(f"# --- begin import {lib_name} ({lib_path}) ---")
        out.append(lib_path.read_text(encoding="utf-8"))
        out.append(f"# --- end import {lib_name} ---")

    return "\n".join(out) + "\n"


def run_script(path: Path, settings: Dict, extra_args: List[str]) -> int:
    if not path.exists():
        print(f"error: script not found: {path}", file=sys.stderr)
        return 1

    shell = script_shell(settings)

    if path.suffix == ".tssh":
        expanded = expand_tssh(path, visited_libs=set())
        with tempfile.NamedTemporaryFile(mode="w", suffix=".sh", delete=False) as tmp:
            tmp.write(expanded)
            tmp_path = Path(tmp.name)
        try:
            result = subprocess.run([shell, str(tmp_path), *extra_args])
            return result.returncode
        finally:
            tmp_path.unlink(missing_ok=True)

    result = subprocess.run([shell, str(path), *extra_args])
    return result.returncode


def apply_aliases(command: str, aliases: Dict[str, str]) -> str:
    parts = command.strip().split(maxsplit=1)
    if not parts:
        return command
    first = parts[0]
    rest = parts[1] if len(parts) > 1 else ""
    if first not in aliases:
        return command
    alias_cmd = aliases[first]
    return f"{alias_cmd} {rest}".strip()


def launch_shell(settings: Dict) -> int:
    shell = script_shell(settings)
    prompt = settings.get("prompt", "Serminal> ")
    aliases = settings.get("aliases", {})

    if settings.get("show_startup_message", True):
        print("Serminal interactive mode. Type ':help' for internal commands.")

    while True:
        try:
            raw = input(prompt)
        except EOFError:
            print()
            break
        except KeyboardInterrupt:
            print()
            continue

        cmd = raw.strip()
        if not cmd:
            continue
        if cmd in {":q", ":quit", ":exit"}:
            break
        if cmd == ":help":
            print(
                ":help                Show this help\n"
                ":aliases             Show configured aliases\n"
                ":set prompt TEXT     Set shell prompt\n"
                ":set shell NAME      Set backend shell (bash, sh, zsh...)\n"
                ":exit                Exit Serminal"
            )
            continue
        if cmd == ":aliases":
            for k, v in aliases.items():
                print(f"{k} -> {v}")
            continue
        if cmd.startswith(":set "):
            _, key, *value_parts = cmd.split()
            value = " ".join(value_parts)
            if key not in {"prompt", "shell"}:
                print("only 'prompt' and 'shell' can be changed from interactive mode")
                continue
            settings[key] = value
            save_settings(settings)
            if key == "shell":
                shell = script_shell(settings)
            if key == "prompt":
                prompt = value
            print(f"updated {key}")
            continue

        expanded_cmd = apply_aliases(raw, aliases)
        subprocess.run(expanded_cmd, shell=True, executable=shell)

    return 0


def settings_show(settings: Dict) -> int:
    print(json.dumps(settings, indent=2, sort_keys=True))
    return 0


def settings_set(settings: Dict, key: str, value: str) -> int:
    if key.startswith("aliases."):
        alias_key = key.split(".", 1)[1]
        settings.setdefault("aliases", {})[alias_key] = value
    elif key.startswith("gui."):
        gui_key = key.split(".", 1)[1]
        settings.setdefault("gui", {})
        if gui_key in {"theme", "font", "logo_mode"}:
            settings["gui"][gui_key] = value
        elif gui_key in {"show_shortcuts", "animations"}:
            settings["gui"][gui_key] = bool_from_text(value)
        else:
            print(f"error: unsupported gui setting '{gui_key}'", file=sys.stderr)
            return 1
    elif key in {"shell", "prompt", "show_startup_message"}:
        if key == "show_startup_message":
            settings[key] = bool_from_text(value)
        else:
            settings[key] = value
    else:
        print(f"error: unsupported setting key '{key}'", file=sys.stderr)
        return 1

    save_settings(settings)
    return 0


def lib_list() -> int:
    ensure_dirs()
    libs = sorted(p.name for p in libs_dir().glob("*.sh"))
    if not libs:
        print("No libraries installed.")
        return 0
    for lib in libs:
        print(lib)
    return 0


def lib_install(name: str, file_path: Path) -> int:
    if not file_path.exists() or not file_path.is_file():
        print(f"error: file not found: {file_path}", file=sys.stderr)
        return 1
    ensure_dirs()
    target = libs_dir() / f"{name}.sh"
    shutil.copyfile(file_path, target)
    print(f"installed {name} -> {target}")
    return 0


def lib_create(name: str) -> int:
    ensure_dirs()
    target = libs_dir() / f"{name}.sh"
    if target.exists():
        print(f"error: library already exists: {target}", file=sys.stderr)
        return 1

    target.write_text(
        "#!/usr/bin/env bash\n"
        "\n"
        f"{name}_hello() {{\n"
        f"  echo \"Hello from {name}\"\n"
        "}\n",
        encoding="utf-8",
    )
    print(f"created {target}")
    return 0


def lib_remove(name: str) -> int:
    target = libs_dir() / f"{name}.sh"
    if not target.exists():
        print(f"error: library not found: {target}", file=sys.stderr)
        return 1
    target.unlink()
    print(f"removed {target}")
    return 0


def desktop_paths(system: bool) -> Tuple[Path, Path]:
    if system:
        apps = Path("/usr/share/applications")
        mime_pkg = Path("/usr/share/mime/packages")
    else:
        if _DATA_DIR_OVERRIDE is not None:
            xdg_data = str(_DATA_DIR_OVERRIDE.parent)
        else:
            xdg_data = os.environ.get("XDG_DATA_HOME", str(runtime_base_dir() / ".local" / "share"))
        apps = Path(xdg_data) / "applications"
        mime_pkg = Path(xdg_data) / "mime" / "packages"
    return apps, mime_pkg


def install_desktop(system: bool) -> int:
    apps, mime_pkg = desktop_paths(system)
    apps.mkdir(parents=True, exist_ok=True)
    mime_pkg.mkdir(parents=True, exist_ok=True)

    entry = apps / "serminal.desktop"
    mime_xml = mime_pkg / "serminal.xml"

    entry.write_text(
        "[Desktop Entry]\n"
        "Type=Application\n"
        "Version=1.0\n"
        "Name=Serminal\n"
        "Comment=Terminal for Open Serialis\n"
        "Exec=serminal start\n"
        "Icon=utilities-terminal\n"
        "Terminal=false\n"
        "Categories=System;TerminalEmulator;\n"
        "MimeType=text/x-serminal-script;application/x-shellscript;\n",
        encoding="utf-8",
    )

    mime_xml.write_text(
        "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
        "<mime-info xmlns=\"http://www.freedesktop.org/standards/shared-mime-info\">\n"
        "  <mime-type type=\"text/x-serminal-script\">\n"
        "    <comment>Serminal script</comment>\n"
        "    <glob pattern=\"*.tssh\"/>\n"
        "  </mime-type>\n"
        "</mime-info>\n",
        encoding="utf-8",
    )

    subprocess.run(["update-desktop-database", str(apps)], check=False)
    subprocess.run(["update-mime-database", str(mime_pkg.parent)], check=False)
    print(f"desktop entry: {entry}")
    print(f"mime package: {mime_xml}")
    return 0


class PtyTab:
    def __init__(self, app: "SerminalGuiApp", title: str) -> None:
        self.app = app
        self.title = title
        self.frame = app.tk.Frame(app.notebook, bg=app.colors["panel"])
        self.scroll = app.tk.Scrollbar(
            self.frame,
            orient="vertical",
            bg=app.colors["muted"],
            troughcolor=app.colors["panel"],
            activebackground=app.colors["accent"],
            relief="flat",
        )
        self.text = app.tk.Text(
            self.frame,
            bg=app.colors["terminal_bg"],
            fg=app.colors["terminal_fg"],
            insertbackground=app.colors["terminal_fg"],
            selectbackground=app.colors["accent_dim"],
            wrap="char",
            undo=False,
            yscrollcommand=self.scroll.set,
            relief="flat",
            bd=0,
            highlightthickness=0,
            padx=14,
            pady=10,
            font=app.mono_font,
        )
        self.scroll.config(command=self.text.yview)
        self.scroll.pack(side="right", fill="y")
        self.text.pack(side="left", fill="both", expand=True)
        self.text.focus_set()
        self.text.mark_set("term_cursor", "end-1c")
        self.text.mark_gravity("term_cursor", "left")

        self.master_fd: Optional[int] = None
        self.pid: Optional[int] = None
        self.closed = False

        self.text.bind("<KeyPress>", self.on_keypress)
        self.text.bind("<Button-1>", self.on_click)
        self.text.bind("<<Paste>>", self.on_paste)
        self.text.bind("<Configure>", self.on_resize)
        self.text.bind("<Control-c>", self.send_ctrl_c)

        self.spawn_shell()

    def spawn_shell(self) -> None:
        shell = script_shell(self.app.settings)
        pid, master_fd = pty.fork()
        if pid == 0:
            os.environ["TERM"] = os.environ.get("TERM", "xterm-256color")
            os.execvp(shell, [shell])
        self.pid = pid
        self.master_fd = master_fd
        flags = fcntl.fcntl(master_fd, fcntl.F_GETFL)
        fcntl.fcntl(master_fd, fcntl.F_SETFL, flags | os.O_NONBLOCK)
        self.resize_pty()

    def resize_pty(self) -> None:
        if self.master_fd is None:
            return
        width = max(self.text.winfo_width(), 200)
        height = max(self.text.winfo_height(), 80)
        font = self.app.tkfont.nametofont("TkFixedFont")
        char_w = max(font.measure("0"), 1)
        char_h = max(font.metrics("linespace"), 1)
        cols = max(width // char_w, 20)
        rows = max(height // char_h, 5)
        winsz = struct_pack_winsize(rows, cols)
        try:
            fcntl.ioctl(self.master_fd, termios.TIOCSWINSZ, winsz)
        except OSError:
            return
        if self.pid is not None:
            try:
                os.kill(self.pid, signal.SIGWINCH)
            except OSError:
                pass

    def on_resize(self, _event) -> None:
        self.resize_pty()

    def append_output(self, data: bytes) -> None:
        text = decode_terminal_stream(data)
        if not text:
            return
        for ch in text:
            cursor = self.text.index("term_cursor")
            if ch == "\b":
                line_start = self.text.index(f"{cursor} linestart")
                if self.text.compare(cursor, ">", line_start):
                    self.text.mark_set("term_cursor", f"{cursor} -1c")
                continue
            if ch == "\r":
                self.text.mark_set("term_cursor", f"{cursor} linestart")
                continue
            if ch == "\n":
                self.text.insert("term_cursor", "\n")
                self.text.mark_set("term_cursor", "term_cursor +1c")
                continue
            if ch == "\t":
                ch = "    "

            next_pos = self.text.index(f"{cursor} +1c")
            at_eof = self.text.compare(cursor, "==", "end-1c")
            next_is_newline = self.text.get(cursor, next_pos) == "\n"
            if not at_eof and not next_is_newline:
                self.text.delete(cursor, next_pos)
            self.text.insert("term_cursor", ch)
            self.text.mark_set("term_cursor", f"{cursor} +{len(ch)}c")
        self.text.see("end")

    def write_to_pty(self, data: bytes) -> None:
        if self.master_fd is None:
            return
        try:
            os.write(self.master_fd, data)
        except OSError:
            self.closed = True

    def on_click(self, _event):
        self.text.focus_set()
        return "break"

    def on_paste(self, _event):
        try:
            clip = self.text.clipboard_get()
        except Exception:
            return "break"
        self.write_to_pty(clip.encode("utf-8", errors="ignore"))
        return "break"

    def send_ctrl_c(self, _event):
        self.write_to_pty(b"\x03")
        return "break"

    def on_keypress(self, event):
        if event.keysym == "BackSpace":
            self.write_to_pty(b"\x7f")
            return "break"
        if event.keysym in {"Return", "KP_Enter"}:
            self.write_to_pty(b"\r")
            return "break"
        if event.keysym == "Tab":
            self.write_to_pty(b"\t")
            return "break"
        if event.keysym == "Escape":
            self.write_to_pty(b"\x1b")
            return "break"
        if event.keysym == "Up":
            self.write_to_pty(b"\x1b[A")
            return "break"
        if event.keysym == "Down":
            self.write_to_pty(b"\x1b[B")
            return "break"
        if event.keysym == "Right":
            self.write_to_pty(b"\x1b[C")
            return "break"
        if event.keysym == "Left":
            self.write_to_pty(b"\x1b[D")
            return "break"
        if event.keysym == "Home":
            self.write_to_pty(b"\x1b[H")
            return "break"
        if event.keysym == "End":
            self.write_to_pty(b"\x1b[F")
            return "break"
        if event.keysym == "Delete":
            self.write_to_pty(b"\x1b[3~")
            return "break"

        ctrl_pressed = bool(event.state & 0x4)
        if ctrl_pressed and event.keysym and len(event.keysym) == 1 and event.keysym.isalpha():
            code = ord(event.keysym.lower()) - ord("a") + 1
            self.write_to_pty(bytes([code]))
            return "break"

        if event.char:
            self.write_to_pty(event.char.encode("utf-8", errors="ignore"))
        return "break"

    def process_output(self) -> None:
        if self.master_fd is None or self.closed:
            return
        while True:
            try:
                data = os.read(self.master_fd, 4096)
                if not data:
                    self.closed = True
                    break
                self.append_output(data)
            except BlockingIOError:
                break
            except OSError as e:
                if e.errno in {errno.EIO, errno.EBADF}:
                    self.closed = True
                    break
                raise

    def check_process(self) -> None:
        if self.pid is None or self.closed:
            return
        try:
            waited_pid, _ = os.waitpid(self.pid, os.WNOHANG)
        except ChildProcessError:
            self.closed = True
            return
        if waited_pid == self.pid:
            self.closed = True

    def close(self) -> None:
        if self.closed:
            return
        self.closed = True
        if self.pid is not None:
            try:
                os.kill(self.pid, signal.SIGHUP)
            except OSError:
                pass
        if self.master_fd is not None:
            try:
                os.close(self.master_fd)
            except OSError:
                pass
            self.master_fd = None


def struct_pack_winsize(rows: int, cols: int) -> bytes:
    # winsize: rows, cols, xpixel, ypixel (all unsigned short)
    return struct.pack("HHHH", rows, cols, 0, 0)


