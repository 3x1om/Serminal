        )
        hints.pack(side="right", padx=(0, 10))

        self.notebook = ttk.Notebook(self.root)
        self.notebook.pack(fill="both", expand=True)
        self.tabs: List[PtyTab] = []

        self.root.bind("<Control-Shift-T>", lambda _e: self.new_tab())
        self.root.bind("<Control-Shift-W>", lambda _e: self.close_current_tab())
        self.root.protocol("WM_DELETE_WINDOW", self.on_close)

        self.new_tab()
        self.schedule_poll()

    def setup_styles(self) -> None:
        style = self.ttk.Style(self.root)
        style.theme_use("clam")
        style.configure(
            "TNotebook",
            background=self.colors["bg"],
            borderwidth=0,
            tabmargins=(12, 8, 12, 0),
        )
        style.configure(
            "TNotebook.Tab",
            background=self.colors["panel_alt"],
            foreground="#d1d5db",
            padding=(14, 8),
            borderwidth=0,
            font=("Noto Sans", 10, "bold"),
        )
        style.map(
            "TNotebook.Tab",
            background=[("selected", self.colors["terminal_bg"]), ("active", self.colors["muted"])],
            foreground=[("selected", "#f9fafb"), ("active", "#f9fafb")],
        )

    def new_tab(self) -> None:
        title = f"Tab {len(self.tabs) + 1}"
        tab = PtyTab(self, title=title)
        self.tabs.append(tab)
        self.notebook.add(tab.frame, text=title)
        self.notebook.select(tab.frame)
        self.refresh_tab_titles()

    def current_tab(self) -> Optional[PtyTab]:
        current_widget = self.notebook.select()
        for tab in self.tabs:
            if str(tab.frame) == current_widget:
                return tab
        return None

    def close_current_tab(self) -> None:
        tab = self.current_tab()
        if tab is None:
            return
        tab.close()
        self.notebook.forget(tab.frame)
        self.tabs = [t for t in self.tabs if t is not tab]
        self.refresh_tab_titles()
        if not self.tabs:
            self.root.destroy()

    def schedule_poll(self) -> None:
        for tab in list(self.tabs):
            tab.process_output()
            tab.check_process()
            if tab.closed:
                try:
                    idx = self.notebook.index(tab.frame)
                    self.notebook.forget(idx)
                except Exception:
                    pass
                self.tabs = [t for t in self.tabs if t is not tab]
                self.refresh_tab_titles()
        if not self.tabs:
            self.root.destroy()
            return
        self.root.after(16, self.schedule_poll)

    def refresh_tab_titles(self) -> None:
        for idx, tab in enumerate(self.tabs, start=1):
            tab.title = f"Tab {idx}"
            self.notebook.tab(tab.frame, text=tab.title)

    def on_close(self) -> None:
        for tab in self.tabs:
            tab.close()
        self.root.destroy()

    def run(self) -> int:
        self.root.mainloop()
        return 0


