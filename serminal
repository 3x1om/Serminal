        def apply_shortcuts_visibility(self) -> None:
            if self.hint_label is None:
                return
            self.hint_label.set_visible(bool(self.gui.get("show_shortcuts", True)))

        def apply_animation_settings(self) -> None:
            self.animations_enabled = bool(self.gui.get("animations", True))
            if self.notebook is not None and not self.animations_enabled:
                self.notebook.set_opacity(1.0)

        def pulse_button(self, button: Optional[Gtk.Button], ms: int = 240) -> None:
            if button is None:
                return
            button.add_css_class("btn-hyde-glow")

            def remove() -> bool:
                button.remove_css_class("btn-hyde-glow")
                return False

            GLib.timeout_add(ms, remove)

        def startup_animation(self) -> None:
            if self.notebook is None:
                return
            if not self.animations_enabled:
                self.notebook.set_opacity(1.0)
                return
            self.notebook.set_opacity(0.0)
            start_us = GLib.get_monotonic_time()
            duration_us = 260_000

            def step() -> bool:
                elapsed = GLib.get_monotonic_time() - start_us
                progress = min(1.0, elapsed / duration_us)
                eased = 1.0 - ((1.0 - progress) ** 3)
                self.notebook.set_opacity(eased)
                return progress < 1.0

            GLib.timeout_add(16, step)
            self.pulse_button(self.btn_new, 300)

        def apply_theme(self) -> None:
            self.theme = gui_theme(self.gui.get("theme", "openserialis"))
            provider = Gtk.CssProvider()
            provider.load_from_data(self.css_for_theme().encode("utf-8"))
            display = Gdk.Display.get_default()
            if self.css_provider is not None:
                Gtk.StyleContext.remove_provider_for_display(display, self.css_provider)
            Gtk.StyleContext.add_provider_for_display(display, provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
            self.css_provider = provider
            for term in self.tabs:
                term.set_font(Pango.FontDescription(self.resolve_terminal_font()))
                term.set_color_background(self.parse_rgba(self.theme["term_bg"]))
                term.set_color_foreground(self.parse_rgba(self.theme["term_fg"]))
                term.set_color_cursor(self.parse_rgba(self.theme["cursor"]))
            self.apply_shortcuts_visibility()
            self.apply_animation_settings()

        def parse_rgba(self, value: str) -> Gdk.RGBA:
            rgba = Gdk.RGBA()
            if not rgba.parse(value):
                rgba = Gdk.RGBA(0, 0, 0, 1)
            return rgba

        def available_font_families(self) -> Set[str]:
            families: Set[str] = set()
            try:
                font_map = Pango.FontMap.get_default()
                for family in font_map.list_families():
                    families.add(family.get_name())
            except Exception:
                return families
            return families

        def available_mono_families(self) -> Set[str]:
            families: Set[str] = set()
            try:
                font_map = Pango.FontMap.get_default()
                for family in font_map.list_families():
                    if family.is_monospace():
                        families.add(family.get_name())
            except Exception:
                return families
            return families

        def resolve_terminal_font(self) -> str:
            configured = str(self.gui.get("font", "")).strip()
            mono_available = self.available_mono_families()
            if configured:
                configured_family = configured.rsplit(" ", 1)[0]
                if configured_family in mono_available:
                    return configured
            available = mono_available
            for candidate in DEFAULT_MONO_FONT_CANDIDATES:
                family = candidate.rsplit(" ", 1)[0]
                if family in available:
                    return candidate
            return "monospace 12"

        def apply_terminal_style(self, term: Vte.Terminal, sixel_enabled: bool) -> str:
            term.set_font(Pango.FontDescription(self.resolve_terminal_font()))
            term.set_color_background(self.parse_rgba(self.theme["term_bg"]))
            term.set_color_foreground(self.parse_rgba(self.theme["term_fg"]))
            term.set_color_cursor(self.parse_rgba(self.theme["cursor"]))
            # Force an opaque terminal layer so text contrast is stable on themed backgrounds.
            if hasattr(term, "set_clear_background"):
                try:
                    term.set_clear_background(True)
                except Exception:
                    pass
            term.set_opacity(1.0)
            logo_mode = str(self.gui.get("logo_mode", "auto")).lower()
            if logo_mode not in self.logo_modes:
                logo_mode = "auto"
            if logo_mode == "auto":
                return "sixel" if sixel_enabled else "chafa"
            if logo_mode == "sixel" and not sixel_enabled:
                return "chafa"
            return logo_mode

        def new_tab(self) -> None:
            term = Vte.Terminal()
            term.set_scrollback_lines(20000)
            # Enable inline image protocols when the local VTE build supports them.
            sixel_enabled = False
            if hasattr(term, "set_enable_sixel"):
                try:
                    term.set_enable_sixel(True)
                    if hasattr(term, "get_enable_sixel"):
                        sixel_enabled = bool(term.get_enable_sixel())
                    else:
                        sixel_enabled = True
                except Exception:
                    sixel_enabled = False
            if hasattr(term, "set_enable_legacy_osc777"):
                try:
                    term.set_enable_legacy_osc777(True)
                except Exception:
                    pass

            env_map = {k: v for k, v in os.environ.items()}
            env_map.setdefault("TERM", "xterm-256color")
            env_map.setdefault("COLORTERM", "truecolor")
            logo_type = self.apply_terminal_style(term, sixel_enabled)
            env_map.setdefault("FASTFETCH_LOGO_TYPE", logo_type)
            env_map.setdefault("FASTFETCH_LOGO_WIDTH", self.default_logo_width)
            env_map.setdefault("FASTFETCH_LOGO_HEIGHT", self.default_logo_height)
            env = [f"{k}={v}" for k, v in env_map.items()]
            argv = [self.shell, "-i"]
            term.spawn_async(
                Vte.PtyFlags.DEFAULT,
                os.getcwd(),
                argv,
                env,
                GLib.SpawnFlags.DEFAULT,
                None,
                None,
                -1,
                None,
                None,
                None,
            )
            term.connect("child-exited", self.on_child_exited, term)

            tab_label = Gtk.Label(label=f"Tab {len(self.tabs) + 1}")
            self.notebook.append_page(term, tab_label)
            self.tabs.append(term)
            self.refresh_tab_titles()
            self.notebook.set_current_page(len(self.tabs) - 1)
            if self.animations_enabled:
                term.set_opacity(0.0)
                start_us = GLib.get_monotonic_time()
                duration_us = 200_000

                def fade_in() -> bool:
                    elapsed = GLib.get_monotonic_time() - start_us
                    progress = min(1.0, elapsed / duration_us)
                    eased = progress * progress * (3 - 2 * progress)
                    term.set_opacity(eased)
                    return progress < 1.0

                GLib.timeout_add(16, fade_in)
                self.pulse_button(self.btn_new, 220)
            self.window.present()

        def close_current_tab(self) -> None:
            idx = self.notebook.get_current_page()
            if idx < 0:
                return
            widget = self.notebook.get_nth_page(idx)
            if widget is None:
                return
            self.notebook.remove_page(idx)
            self.tabs = [t for t in self.tabs if t is not widget]
            self.refresh_tab_titles()
            if not self.tabs:
                self.quit()

        def open_settings(self) -> None:
            dialog = Gtk.Dialog(transient_for=self.window, modal=True, title="Serminal Settings")
            dialog.set_default_size(460, 280)
            dialog.add_button("Cancel", Gtk.ResponseType.CANCEL)
            dialog.add_button("Save", Gtk.ResponseType.OK)

            content = dialog.get_content_area()
            grid = Gtk.Grid(column_spacing=12, row_spacing=10, margin_top=12, margin_bottom=12, margin_start=12, margin_end=12)
            content.append(grid)

            shell_entry = Gtk.Entry(text=self.settings.get("shell", "bash"))
            font_entry = Gtk.Entry(text=str(self.gui.get("font", DEFAULT_SETTINGS["gui"]["font"])))
            theme_dropdown = Gtk.DropDown.new_from_strings(self.theme_names)
            logo_dropdown = Gtk.DropDown.new_from_strings(self.logo_modes)
            shortcuts_switch = Gtk.Switch(active=bool(self.gui.get("show_shortcuts", True)))
            animations_switch = Gtk.Switch(active=bool(self.gui.get("animations", True)))

            try:
                theme_dropdown.set_selected(self.theme_names.index(self.gui.get("theme", "openserialis")))
            except ValueError:
                theme_dropdown.set_selected(0)
            try:
                logo_dropdown.set_selected(self.logo_modes.index(str(self.gui.get("logo_mode", "auto")).lower()))
            except ValueError:
                logo_dropdown.set_selected(0)

            def add_row(row: int, label_text: str, widget) -> None:
                label = Gtk.Label(label=label_text, xalign=0)
                grid.attach(label, 0, row, 1, 1)
                grid.attach(widget, 1, row, 1, 1)

            add_row(0, "Shell", shell_entry)
            add_row(1, "Font", font_entry)
            add_row(2, "Theme", theme_dropdown)
            add_row(3, "Logo Mode", logo_dropdown)
            add_row(4, "Show Shortcuts", shortcuts_switch)
            add_row(5, "Animations (HyDE)", animations_switch)

            def on_response(dlg: Gtk.Dialog, response_id: int) -> None:
                if response_id == Gtk.ResponseType.OK:
                    new_shell = shell_entry.get_text().strip() or "bash"
                    if shutil.which(new_shell) is None:
                        new_shell = self.settings.get("shell", "bash")
                    self.settings["shell"] = new_shell
                    self.settings.setdefault("gui", {})
                    self.settings["gui"]["font"] = font_entry.get_text().strip() or DEFAULT_SETTINGS["gui"]["font"]
                    self.settings["gui"]["theme"] = self.theme_names[theme_dropdown.get_selected()]
                    self.settings["gui"]["logo_mode"] = self.logo_modes[logo_dropdown.get_selected()]
                    self.settings["gui"]["show_shortcuts"] = shortcuts_switch.get_active()
                    self.settings["gui"]["animations"] = animations_switch.get_active()
                    self.shell = script_shell(self.settings)
                    self.gui = gui_settings(self.settings)
                    save_settings(self.settings)
                    self.apply_theme()
                dlg.destroy()

            dialog.connect("response", on_response)
            dialog.present()

        def on_child_exited(self, _term: Vte.Terminal, _status: int, term: Vte.Terminal) -> None:
            idx = self.notebook.page_num(term)
            if idx >= 0:
                self.notebook.remove_page(idx)
            self.tabs = [t for t in self.tabs if t is not term]
            self.refresh_tab_titles()
            if not self.tabs:
                self.quit()

        def refresh_tab_titles(self) -> None:
            for idx, term in enumerate(self.tabs, start=1):
                label = self.notebook.get_tab_label(term)
                if isinstance(label, Gtk.Label):
                    label.set_label(f"Tab {idx}")

    app = VteSerminalApp()
    return app.run([])


def decode_terminal_stream(data: bytes) -> str:
    text = data.decode("utf-8", errors="replace")
    text = ANSI_OSC_RE.sub("", text)
    text = ANSI_CSI_RE.sub("", text)
    text = ANSI_ESC_RE.sub("", text)
    # Keep printable text + terminal control chars we emulate.
    return "".join(ch for ch in text if ch in {"\n", "\r", "\t", "\b"} or ch >= " ")


def start_best_mode(settings: Dict) -> int:
    return launch_gui(settings)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(prog="serminal", description="Serminal terminal toolkit")
    sub = parser.add_subparsers(dest="cmd", required=True)

    sub.add_parser("start", help="Start Serminal GUI (same as 'gui')")
    sub.add_parser("shell", help="Launch interactive Serminal shell")
    sub.add_parser("gui", help="Launch tabbed PTY terminal GUI")

    run_p = sub.add_parser("run", help="Run a .sh or .tssh script")
    run_p.add_argument("script")
    run_p.add_argument("script_args", nargs=argparse.REMAINDER)

    settings_p = sub.add_parser("settings", help="Manage settings")
    settings_sub = settings_p.add_subparsers(dest="settings_cmd", required=True)
    settings_sub.add_parser("show")
    set_p = settings_sub.add_parser("set")
    set_p.add_argument("key")
    set_p.add_argument("value")

    lib_p = sub.add_parser("lib", help="Manage script libraries")
    lib_sub = lib_p.add_subparsers(dest="lib_cmd", required=True)
    lib_sub.add_parser("list")
    create_p = lib_sub.add_parser("create")
    create_p.add_argument("name")
    install_p = lib_sub.add_parser("install")
    install_p.add_argument("name")
    install_p.add_argument("file")
    remove_p = lib_sub.add_parser("remove")
    remove_p.add_argument("name")

    desktop_p = sub.add_parser("install-desktop", help="Install desktop entry + MIME type")
    desktop_p.add_argument("--system", action="store_true", help="Install in /usr/share (requires root)")

    return parser.parse_args()


def main() -> int:
    args = parse_args()
    settings = load_settings()

    if args.cmd == "start":
        rc = start_best_mode(settings)
        if rc == 2:
            print(
                "error: GTK/VTE backend missing. Install: python-gobject gtk4 vte4 chafa (CachyOS/Arch).",
                file=sys.stderr,
            )
            return 1
        if rc == 3:
            print("error: no graphical display found (X11/Wayland).", file=sys.stderr)
            return 1
        return rc
    if args.cmd == "shell":
        return launch_shell(settings)
    if args.cmd == "gui":
        rc = launch_gui(settings)
        if rc == 2:
            print(
                "error: GTK/VTE backend missing. Install: python-gobject gtk4 vte4 chafa (CachyOS/Arch).",
                file=sys.stderr,
            )
            return 1
        if rc == 3:
            print("error: no graphical display found (X11/Wayland).", file=sys.stderr)
            return 1
        return rc

    if args.cmd == "run":
        return run_script(Path(args.script), settings, args.script_args)

    if args.cmd == "settings":
        if args.settings_cmd == "show":
            return settings_show(settings)
        if args.settings_cmd == "set":
            return settings_set(settings, args.key, args.value)

    if args.cmd == "lib":
        if args.lib_cmd == "list":
            return lib_list()
        if args.lib_cmd == "create":
            return lib_create(args.name)
        if args.lib_cmd == "install":
            return lib_install(args.name, Path(args.file))
        if args.lib_cmd == "remove":
            return lib_remove(args.name)

    if args.cmd == "install-desktop":
        return install_desktop(args.system)

    return 1


if __name__ == "__main__":
    raise SystemExit(main())
